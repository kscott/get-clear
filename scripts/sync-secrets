#!/usr/bin/env bash
# sync-secrets — push signing and notarization secrets to all Get Clear repos
#
# Reads credentials from the local Keychain (service: get-clear-signing).
# Run this after any credential change: new cert, rotated app-specific password, etc.
#
# Usage:
#   ./scripts/sync-secrets
#
# To update a credential before syncing:
#   security add-generic-password -s "get-clear-signing" -a "p12-base64"        -w "$(base64 -i /path/to/new.p12)" -U
#   security add-generic-password -s "get-clear-signing" -a "p12-password"       -w "new-password" -U
#   security add-generic-password -s "get-clear-signing" -a "notarytool-password" -w "xxxx-xxxx-xxxx-xxxx" -U
#   Then run: ./scripts/sync-secrets

set -euo pipefail

REPOS=(
  kscott/reminders-cli
  kscott/calendar-cli
  kscott/contacts-cli
  kscott/mail-cli
  kscott/sms-cli
)

echo "Reading credentials from Keychain..."
P12_B64=$(security find-generic-password -s "get-clear-signing" -a "p12-base64"         -w)
P12_PASS=$(security find-generic-password -s "get-clear-signing" -a "p12-password"       -w)
NOTARY_PW=$(security find-generic-password -s "get-clear-signing" -a "notarytool-password" -w)
APPLE_ID=$(security find-generic-password -s "get-clear-signing" -a "apple-id"           -w)
TEAM_ID=$(security find-generic-password -s "get-clear-signing" -a "team-id"             -w)

echo "Syncing to ${#REPOS[@]} repos..."
for repo in "${REPOS[@]}"; do
  echo "  $repo"
  gh secret set DEVELOPER_ID_P12          --body "$P12_B64"   --repo "$repo"
  gh secret set DEVELOPER_ID_P12_PASSWORD --body "$P12_PASS"  --repo "$repo"
  gh secret set NOTARYTOOL_APPLE_ID       --body "$APPLE_ID"  --repo "$repo"
  gh secret set NOTARYTOOL_PASSWORD       --body "$NOTARY_PW" --repo "$repo"
  gh secret set NOTARYTOOL_TEAM_ID        --body "$TEAM_ID"   --repo "$repo"
done

echo "Done. All secrets synced."
