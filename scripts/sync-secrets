#!/usr/bin/env bash
# sync-secrets — push signing and notarization secrets to all Get Clear repos
#
# Reads credentials from the local Keychain (service: get-clear-signing).
# Run this after any credential change: new cert, rotated app-specific password, etc.
#
# Usage:
#   ./scripts/sync-secrets
#
# To update a credential before syncing:
#   security add-generic-password -s "get-clear-signing" -a "p12-base64"           -w "$(base64 -i /path/to/new.p12)" -U
#   security add-generic-password -s "get-clear-signing" -a "p12-password"          -w "new-password" -U
#   security add-generic-password -s "get-clear-signing" -a "notarytool-password"   -w "xxxx-xxxx-xxxx-xxxx" -U
#   security add-generic-password -s "get-clear-signing" -a "installer-p12-base64"  -w "$(base64 -i /path/to/installer.p12)" -U
#   security add-generic-password -s "get-clear-signing" -a "installer-p12-password" -w "new-password" -U
#   Then run: ./scripts/sync-secrets

set -euo pipefail

TOOL_REPOS=(
  kscott/reminders-cli
  kscott/calendar-cli
  kscott/contacts-cli
  kscott/mail-cli
  kscott/sms-cli
)

UMBRELLA_REPO="kscott/get-clear"

echo "Reading credentials from Keychain..."
P12_B64=$(security find-generic-password -s "get-clear-signing" -a "p12-base64"          -w)
P12_PASS=$(security find-generic-password -s "get-clear-signing" -a "p12-password"        -w)
NOTARY_PW=$(security find-generic-password -s "get-clear-signing" -a "notarytool-password" -w)
APPLE_ID=$(security find-generic-password -s "get-clear-signing"  -a "apple-id"           -w)
TEAM_ID=$(security find-generic-password -s "get-clear-signing"   -a "team-id"            -w)

# Installer cert is only needed by the umbrella repo PKG build.
# If not yet in Keychain, the umbrella sync step will be skipped with a warning.
INSTALLER_P12_B64=""
INSTALLER_P12_PASS=""
if security find-generic-password -s "get-clear-signing" -a "installer-p12-base64" -w &>/dev/null; then
  INSTALLER_P12_B64=$(security find-generic-password -s "get-clear-signing" -a "installer-p12-base64"   -w)
  INSTALLER_P12_PASS=$(security find-generic-password -s "get-clear-signing" -a "installer-p12-password" -w)
else
  echo "  Warning: installer-p12-base64 not found in Keychain."
  echo "  Create a Developer ID Installer cert, then store it:"
  echo "    security add-generic-password -s get-clear-signing -a installer-p12-base64  -w \"\$(base64 -i /path/to/installer.p12)\" -U"
  echo "    security add-generic-password -s get-clear-signing -a installer-p12-password -w your-password -U"
  echo "  Umbrella repo PKG secrets will be skipped."
  echo ""
fi

echo "Syncing to tool repos..."
for repo in "${TOOL_REPOS[@]}"; do
  echo "  $repo"
  gh secret set DEVELOPER_ID_P12          --body "$P12_B64"   --repo "$repo"
  gh secret set DEVELOPER_ID_P12_PASSWORD --body "$P12_PASS"  --repo "$repo"
  gh secret set NOTARYTOOL_APPLE_ID       --body "$APPLE_ID"  --repo "$repo"
  gh secret set NOTARYTOOL_PASSWORD       --body "$NOTARY_PW" --repo "$repo"
  gh secret set NOTARYTOOL_TEAM_ID        --body "$TEAM_ID"   --repo "$repo"
done

echo "Syncing to umbrella repo ($UMBRELLA_REPO)..."
gh secret set NOTARYTOOL_APPLE_ID --body "$APPLE_ID"  --repo "$UMBRELLA_REPO"
gh secret set NOTARYTOOL_PASSWORD --body "$NOTARY_PW" --repo "$UMBRELLA_REPO"
gh secret set NOTARYTOOL_TEAM_ID  --body "$TEAM_ID"   --repo "$UMBRELLA_REPO"

if [[ -n "$INSTALLER_P12_B64" ]]; then
  gh secret set DEVELOPER_ID_INSTALLER_P12          --body "$INSTALLER_P12_B64"  --repo "$UMBRELLA_REPO"
  gh secret set DEVELOPER_ID_INSTALLER_P12_PASSWORD --body "$INSTALLER_P12_PASS" --repo "$UMBRELLA_REPO"
  echo "  Installer cert secrets synced."
else
  echo "  Installer cert secrets skipped (not in Keychain)."
fi

echo ""
echo "Done."
